Options -MultiViews -Indexes

RewriteEngine On
# ------------------------------------------------------------------------------------
# IMPORTANT: FOR LOCALHOST USE: RewriteBase /new_food/admin/
# IMPORTANT: FOR LIVE SERVER USE: RewriteBase /admin/
# ------------------------------------------------------------------------------------
RewriteBase /new_food/admin/

# 1. Redirect index.php to root of admin
RewriteRule ^index\.php$ ./ [R=301,L]

# 2. Support Clean URLs (remove .php)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^/]+)$ $1.php [L]

# 3. Security: Disable directory listing
Options -Indexes
