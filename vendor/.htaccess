RewriteEngine On
RewriteBase /vendor/
# 1. Redirect index.php to root of vendor
RewriteRule ^index\.php$ ./ [R=301,L]

# 2. Support Clean URLs (remove .php)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^/]+)$ $1.php [L]

# 3. Security: Disable directory listing
Options -Indexes
